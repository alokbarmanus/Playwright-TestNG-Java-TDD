<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng-dev.xml  -  DEV environment test suite
  Run: mvn clean test -Denv=dev
-->
<suite name="OrangeHRM Test Suite - DEV" verbose="1">

    <listeners>
        <listener class-name="com.orangehrm.listeners.ExtentReportListener"/>
    </listeners>

    <test name="Login Tests - DEV">
        <packages>
            <package name="com.orangehrm.tests"/>
        </packages>
    </test>

</suite>
