<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng-sit.xml  -  SIT environment test suite
  Run: mvn clean test -Denv=sit
-->
<suite name="OrangeHRM Test Suite - SIT" verbose="1">

    <listeners>
        <listener class-name="com.orangehrm.listeners.ExtentReportListener"/>
    </listeners>

    <test name="Login Tests - SIT">
        <packages>
            <package name="com.orangehrm.tests"/>
        </packages>
    </test>

</suite>
