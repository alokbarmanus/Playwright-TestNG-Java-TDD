<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng-uat.xml  -  UAT environment test suite
  Run: mvn clean test -Denv=uat
-->
<suite name="OrangeHRM Test Suite - UAT" verbose="1">

    <listeners>
        <listener class-name="com.orangehrm.listeners.ExtentReportListener"/>
    </listeners>

    <test name="Login Tests - UAT">
        <packages>
            <package name="com.orangehrm.tests"/>
        </packages>
    </test>

</suite>
